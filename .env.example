###############################################################################
# ERPNext base-image template — environment variables
# Copy to `.env` and adjust. Values below are sane dev defaults.
###############################################################################

# ----------------------------------------------------------------------------
# Environment mode
# ----------------------------------------------------------------------------
# "dev" (or unset) => hot-reload dev server (bench start) + auto-scaffold of
# declared-but-missing custom apps. Any other value (e.g. "production",
# "staging") runs the full production stack (web + workers + scheduler).
# On Railway, set: PROJECT_ENV="${{RAILWAY_ENVIRONMENT}}" (don't name a Railway
# environment "dev", or it would trigger hot-reload mode in the cloud).
PROJECT_ENV=dev

# ----------------------------------------------------------------------------
# Site
# ----------------------------------------------------------------------------
SITE_NAME=site.local
ADMIN_PASSWORD=admin123

# ----------------------------------------------------------------------------
# Database (MariaDB). On Railway, source these from the MariaDB plugin, e.g.:
#   DB_HOST="${{MariaDB.MARIADB_HOST}}"
#   DB_PORT="${{MariaDB.MARIADB_PORT}}"
#   DB_ROOT_PASSWORD="${{MariaDB.MARIADB_ROOT_PASSWORD}}"
# DB_NAME is fixed so the site reconnects to the same DB across redeploys.
# ----------------------------------------------------------------------------
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=erpnext
DB_ROOT_PASSWORD=supersecret

# ----------------------------------------------------------------------------
# Redis (Cache / Queue / SocketIO). Locally all three can point at one Redis.
# On Railway, use three Redis services and inject their REDIS_URLs.
# ----------------------------------------------------------------------------
REDIS_CACHE_URL=redis://redis:6379
REDIS_QUEUE_URL=redis://redis:6379
REDIS_SOCKETIO_URL=redis://redis:6379

# ----------------------------------------------------------------------------
# Encryption key (CRITICAL for production / persistence)
# ----------------------------------------------------------------------------
# Generate ONCE and keep forever. If the site config is ever regenerated, the
# pinned key keeps stored passwords decryptable. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty locally to let Frappe generate one on first create.
ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Web port. Railway injects $PORT; locally defaults to 8000.
# ----------------------------------------------------------------------------
# PORT=8000

# Port the Socket.IO (realtime) node server listens on (nginx proxies
# /socket.io/ to it). Default 9000; rarely needs changing.
# SOCKETIO_PORT=9000

# ----------------------------------------------------------------------------
# Production tuning (optional)
# ----------------------------------------------------------------------------
# Number of gunicorn workers for the web process in production.
# GUNICORN_WORKERS=2

# ----------------------------------------------------------------------------
# Backups (optional S3-compatible offload). When set, pre-migrate and
# scheduled backups are pushed to object storage in addition to the volume.
# ----------------------------------------------------------------------------
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_BUCKET=my-erpnext-backups
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# Local backup retention: how many recent backups to keep on the volume.
# BACKUP_KEEP=7
# Minimum free MB required on the volume before a backup/migrate runs.
# BACKUP_MIN_FREE_MB=1024
# Pre-migrate backups are DATABASE-ONLY by default (fast). Set to 1 to also
# back up uploaded public/private files (slower, more disk).
# BACKUP_WITH_FILES=0

# ----------------------------------------------------------------------------
# Upgrade guards (leave UNSET in steady state). Only set these to acknowledge a
# MAJOR version change so the entrypoint will run the migration instead of
# hard-stopping. See README "Upgrading".
# ----------------------------------------------------------------------------
# UPGRADE_ERPNEXT_VERSION=16
# UPGRADE_DB_VERSION=11.4
# Auto-restore the pre-migrate backup if a migration fails (default off).
# AUTO_RESTORE_ON_FAIL=0
