# =============================================================================
# release.env — pinned version defaults for THIS branch.
#
# This is the ONLY file that differs between `main` and the `release/vN`
# branches. It is protected by a `merge=ours` git driver (see .gitattributes),
# so merging `main` into a release branch never overwrites these pins and never
# conflicts. See README "Release Branches".
#
# Simplest: use the erpnext wrapper, which loads this file + .env automatically:
#   ./erpnext up --build    (Windows cmd/PowerShell:  .\erpnext up --build)
# Or pass BOTH files yourself — a lone --env-file replaces the default .env,
# so list .env too:
#   docker compose --env-file .env --env-file deploy/release.env up --build
#
# On Railway (managed MariaDB, no compose), set ERPNEXT_VERSION as a per-service
# BUILD variable matching the value below.
# =============================================================================

# ERPNext base image tag. MUST match the major of every external app branch in
# user-apps.json. Required at build time — the Dockerfile guard stops the build
# if it is missing.
ERPNEXT_VERSION=v15.111.0

# MariaDB image tag (local / compose only). Required by docker-compose.yml —
# Compose fails fast if it is unset. Not used on Railway (managed MariaDB).
MARIADB_VERSION=10.6

# NOTE: external app branches are intentionally NOT pinned here — branch naming
# is not standard across Frappe apps. Set each app's branch explicitly in
# deploy/user-apps.json ("external[].branch").
